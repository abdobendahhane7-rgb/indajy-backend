generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  FARMER
  DISTRIBUTOR
  DRIVER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ListingStatus {
  ACTIVE
  OUT_OF_STOCK
  INACTIVE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_TRANSIT
  COMPLETED
  CANCELLED
  REJECTED
}

enum WalletTransactionType {
  CREDIT
  DEPOSIT
  ORDER_FEE
  REFUND
  ADJUSTMENT
}

enum WalletTransactionStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model User {
  id                 String         @id @default(cuid())
  fullName           String
  phone              String         @unique
  email              String?        @unique
  passwordHash       String
  role               UserRole
  approvalStatus     ApprovalStatus @default(PENDING)
  city               String?
  address            String?
  latitude           Float?
  longitude          Float?
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  favorites          Favorite[]
  notifications      Notification[]
  documents          UserDocument[]
  listings           Listing[]      @relation("FarmerListings")
  orders             Order[]        @relation("DistributorOrders")
  driverOrders       Order[]        @relation("DriverOrders")
  wallet             Wallet?

  sentMessages       ChatMessage[]      @relation("MessageSender")
  participantOne     ChatConversation[] @relation("ConversationUserOne")
  participantTwo     ChatConversation[] @relation("ConversationUserTwo")

  walletTransactions WalletTransaction[] @relation("WalletUserTransactions")
}

model UserDocument {
  id         String   @id @default(cuid())
  userId     String
  cinUrl     String?
  onssaUrl   String?
  legalUrl   String?
  driverUrl  String?
  vehicleUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Listing {
  id              String        @id @default(cuid())
  farmerId        String
  title           String
  category        String
  variant         String
  description     String?
  quantityKg      Float
  availableKg     Float
  pricePerKg      Decimal       @db.Decimal(12, 2)
  totalStockValue Decimal       @db.Decimal(12, 2)
  city            String
  address         String?
  latitude        Float
  longitude       Float
  status          ListingStatus @default(ACTIVE)
  isGpsEnabled    Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  favorites       Favorite[]
  farmer          User          @relation("FarmerListings", fields: [farmerId], references: [id], onDelete: Cascade)
  images          ListingImage[]
  orders          Order[]
  conversations   ChatConversation[]

  @@index([farmerId])
  @@index([city])
  @@index([status])
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  imageUrl  String
  createdAt DateTime @default(now())

  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model Order {
  id              String      @id @default(cuid())
  listingId       String
  distributorId   String
  driverId        String?
  quantityKg      Float
  pricePerKg      Decimal     @db.Decimal(12, 2)
  subtotal        Decimal     @db.Decimal(12, 2)
  operationFee    Decimal     @db.Decimal(12, 2)
  totalAmount     Decimal     @db.Decimal(12, 2)
  deliveryAddress String?
  deliveryCity    String?
  deliveryLat     Float?
  deliveryLng     Float?
  note            String?
  status          OrderStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tracking        OrderTracking[]
  listing         Listing     @relation(fields: [listingId], references: [id], onDelete: Restrict)
  distributor     User        @relation("DistributorOrders", fields: [distributorId], references: [id], onDelete: Restrict)
  driver          User?       @relation("DriverOrders", fields: [driverId], references: [id], onDelete: SetNull)

  @@index([listingId])
  @@index([distributorId])
  @@index([driverId])
  @@index([status])
}

model Wallet {
  id           String   @id @default(cuid())
  userId       String   @unique
  balance      Decimal  @default(0) @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@index([userId])
}

model WalletTransaction {
  id        String                  @id @default(cuid())
  walletId  String
  userId    String
  type      WalletTransactionType
  status    WalletTransactionStatus @default(PENDING)
  amount    Decimal                 @db.Decimal(12, 2)
  fee       Decimal                 @default(0) @db.Decimal(12, 2)
  netAmount Decimal                 @default(0) @db.Decimal(12, 2)
  note      String?
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  wallet    Wallet                  @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user      User                    @relation("WalletUserTransactions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([userId])
  @@index([type])
  @@index([status])
}

model AppSetting {
  id             String   @id @default(cuid())
  operationFee   Decimal  @default(10) @db.Decimal(12, 2)
  rechargeFee    Decimal  @default(0) @db.Decimal(12, 2)
  minOrderKg     Float    @default(1)
  isOrderingOpen Boolean  @default(true)
  updatedAt      DateTime @updatedAt
}

model ChatConversation {
  id            String        @id @default(cuid())
  userOneId     String
  userTwoId     String
  listingId     String?
  lastMessageAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  userOne       User          @relation("ConversationUserOne", fields: [userOneId], references: [id], onDelete: Cascade)
  userTwo       User          @relation("ConversationUserTwo", fields: [userTwoId], references: [id], onDelete: Cascade)
  listing       Listing?      @relation(fields: [listingId], references: [id], onDelete: SetNull)
  messages      ChatMessage[]

  @@index([userOneId])
  @@index([userTwoId])
  @@index([listingId])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())

  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User             @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

model OrderTracking {
  id        String   @id @default(cuid())
  orderId   String
  driverId  String?
  lat       Float
  lng       Float
  speed     Float?
  heading   Float?
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([driverId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}