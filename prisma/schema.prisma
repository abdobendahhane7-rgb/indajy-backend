generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  FARMER
  DISTRIBUTOR
  ADMIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentType {
  CIN
  LEGAL_LICENSE
  ONSSA_HEALTH_LICENSE
  DRIVER_LICENSE
  VEHICLE_REGISTRATION
  ONSSA_AUTHORIZATION
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WalletTransactionType {
  TOP_UP
  PURCHASE
  SALE_INCOME
  COMMISSION
  REFUND
  MANUAL_ADJUSTMENT
}

enum WalletTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum TopUpRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
}

enum NotificationType {
  ACCOUNT_APPROVED
  ACCOUNT_REJECTED
  NEW_ORDER
  ORDER_ACCEPTED
  ORDER_REJECTED
  ORDER_COMPLETED
  TOPUP_APPROVED
  TOPUP_REJECTED
  WALLET_UPDATED
  GENERAL
}

model User {
  id              String         @id @default(cuid())
  fullName        String
  phone           String         @unique
  email           String?        @unique
  passwordHash    String
  role            UserRole
  city            String?
  fcmToken        String?
  isActive        Boolean        @default(true)
  isVerified      Boolean        @default(false)
  approvalStatus  ApprovalStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  location                 UserLocation?
  wallet                   Wallet?
  documents                VerificationDocument[]
  userDocuments            UserDocument[]
  topUpRequests            TopUpRequest[]
  listings                 ProductListing[]       @relation("FarmerListings")
  farmerOrders             Order[]                @relation("FarmerOrders")
  distributorOrders        Order[]                @relation("DistributorOrders")
  notifications            Notification[]
  adminLogs                AdminLog[]             @relation("AdminLogs")
  reviewedDocuments        VerificationDocument[] @relation("ReviewedDocuments")
  reviewedTopUps           TopUpRequest[]         @relation("ReviewedTopUps")
  walletTransactions       WalletTransaction[]    @relation("UserWalletTransactions")
  farmerConversations      ChatConversation[]     @relation("FarmerConversations")
  distributorConversations ChatConversation[]     @relation("DistributorConversations")
  chatMessages             ChatMessage[]
}

model UserLocation {
  id        String   @id @default(cuid())
  userId    String   @unique
  city      String
  address   String?
  latitude  Decimal  @db.Decimal(10, 7)
  longitude Decimal  @db.Decimal(10, 7)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([city])
  @@index([latitude, longitude])
}

model VerificationDocument {
  id              String         @id @default(cuid())
  userId          String
  documentType    DocumentType
  fileUrl         String
  filePublicId    String?
  status          DocumentStatus @default(PENDING)
  rejectionReason String?
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ReviewedDocuments", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([documentType])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  currency  String   @default("MAD")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  WalletTransaction[]
  topUpRequests TopUpRequest[]

  @@index([userId])
}

model WalletTransaction {
  id               String                  @id @default(cuid())
  walletId         String
  userId           String
  type             WalletTransactionType
  amount           Decimal                 @db.Decimal(12, 2)
  status           WalletTransactionStatus @default(COMPLETED)
  reference        String?
  note             String?
  relatedOrderId   String?
  createdByAdminId String?
  createdAt        DateTime                @default(now())

  wallet       Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user         User   @relation("UserWalletTransactions", fields: [userId], references: [id], onDelete: Cascade)
  relatedOrder Order? @relation(fields: [relatedOrderId], references: [id], onDelete: SetNull)

  @@index([walletId])
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([relatedOrderId])
}

model TopUpRequest {
  id              String             @id @default(cuid())
  userId          String
  walletId        String
  amount          Decimal            @db.Decimal(12, 2)
  proofImageUrl   String?
  note            String?
  status          TopUpRequestStatus @default(PENDING)
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet     Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  reviewedBy User?  @relation("ReviewedTopUps", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([walletId])
  @@index([status])
}

model ProductListing {
  id                String   @id @default(cuid())
  farmerId          String
  title             String
  description       String?
  poultryType       String
  quantity          Int
  availableQuantity Int
  unitPrice         Decimal  @db.Decimal(12, 2)
  averageWeightKg   Decimal? @db.Decimal(8, 2)
  city              String
  latitude          Decimal  @db.Decimal(10, 7)
  longitude         Decimal  @db.Decimal(10, 7)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  farmer User           @relation("FarmerListings", fields: [farmerId], references: [id], onDelete: Cascade)
  images ProductImage[]
  orders Order[]

  @@index([farmerId])
  @@index([city])
  @@index([poultryType])
  @@index([isActive])
  @@index([latitude, longitude])
}

model ProductImage {
  id        String   @id @default(cuid())
  listingId String
  imageUrl  String
  createdAt DateTime @default(now())

  listing ProductListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model Order {
  id               String      @id @default(cuid())
  orderNumber      String      @unique
  listingId        String
  farmerId         String
  distributorId    String
  quantity         Int
  unitPrice        Decimal     @db.Decimal(12, 2)
  subtotal         Decimal     @db.Decimal(12, 2)
  commissionRate   Decimal     @db.Decimal(5, 2)
  commissionAmount Decimal     @db.Decimal(12, 2)
  totalAmount      Decimal     @db.Decimal(12, 2)
  status           OrderStatus @default(PENDING)
  note             String?
  acceptedAt       DateTime?
  rejectedAt       DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  listing            ProductListing      @relation(fields: [listingId], references: [id], onDelete: Restrict)
  farmer             User                @relation("FarmerOrders", fields: [farmerId], references: [id], onDelete: Restrict)
  distributor        User                @relation("DistributorOrders", fields: [distributorId], references: [id], onDelete: Restrict)
  notifications      Notification[]
  walletTransactions WalletTransaction[]
  conversation       ChatConversation?   @relation("OrderConversation")

  @@index([listingId])
  @@index([farmerId])
  @@index([distributorId])
  @@index([status])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  orderId   String?
  title     String
  body      String
  type      String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orderId])
  @@index([createdAt])
  @@index([isRead])
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  note       String?
  createdAt  DateTime @default(now())

  admin User @relation("AdminLogs", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([targetType])
  @@index([targetId])
  @@index([createdAt])
}

model UserDocument {
  id         String   @id @default(uuid())
  userId     String
  role       UserRole
  cinUrl     String?
  onssaUrl   String?
  legalUrl   String?
  driverUrl  String?
  vehicleUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ChatConversation {
  id            String   @id @default(cuid())
  farmerId      String
  distributorId String
  orderId       String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  farmer      User          @relation("FarmerConversations", fields: [farmerId], references: [id], onDelete: Cascade)
  distributor User          @relation("DistributorConversations", fields: [distributorId], references: [id], onDelete: Cascade)
  order       Order?        @relation("OrderConversation", fields: [orderId], references: [id], onDelete: SetNull)
  messages    ChatMessage[]

  @@index([farmerId])
  @@index([distributorId])
  @@index([orderId])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  text           String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User             @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}
